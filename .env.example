PORT=3000

# Optional: use a single connection string instead of DB_* fields
# DATABASE_URL=postgresql://user:pass@host:5432/dbname?sslmode=require
# DB_SSL=true

DB_HOST=localhost
DB_PORT=5432
DB_NAME=inventory_dev
DB_USER=postgres
DB_PASSWORD=change_me

JWT_SECRET=replace_with_long_random_secret
JWT_EXPIRES_IN=12h
PASSWORD_SALT_ROUNDS=10
# Set true in production so API routes require a valid JWT.
REQUIRE_AUTH=false

# Simple admin UI (users + row counts): after starting the server, open
#   http://localhost:3000/admin
# Sign in with an account that has role admin (see ADMIN_EMAIL below).

# Allow technicians to create their own account (role tech) from the app. Set false to admin-only onboarding.
ALLOW_SELF_SIGNUP=true

# Optional first admin seed on startup
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change_me
ADMIN_NAME=Inventory Admin
